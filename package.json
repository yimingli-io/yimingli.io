{
  "name": "yimingli-website",
  "version": "0.8.1.1",
  "description": "Yiming Li's personal website — Jekyll (Academic Pages) on Cloudflare Workers",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/yimingli-io/yimingli.io"
  },
  "keywords": [
    "jekyll",
    "theme",
    "minimal"
  ],
  "contributors": [
    "Michael Rose",
    "Robert Zupko"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yimingli-io/yimingli.io/issues"
  },
  "homepage": "https://yimingli.io",
  "engines": {
    "node": ">= 0.10.0"
  },
  "dependencies": {
    "fitvids": "^2.1.1",
    "jquery": "^3.7.1",
    "jquery-smooth-scroll": "^2.2.0"
  },
  "devDependencies": {
    "onchange": "^7.1.0",
    "uglify-js": "^3.17.4",
    "wrangler": "^4.0.0"
  },
  "scripts": {
    "build": "bundle exec jekyll build",
    "deploy": "npm run build && wrangler deploy",
    "uglify": "uglifyjs node_modules/jquery/dist/jquery.min.js node_modules/fitvids/dist/fitvids.min.js node_modules/jquery-smooth-scroll/jquery.smooth-scroll.min.js assets/js/plugins/jquery.greedy-navigation.js assets/js/_main.js -c -m -o assets/js/main.min.js",
    "watch:js": "onchange \"assets/js/**/*.js\" -e \"assets/js/main.min.js\" -- npm run build:js",
    "build:js": "npm run uglify"
  }
}
